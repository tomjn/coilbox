{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coilbox",
  "version": "0.0.0",
  "identifier": "com.tomjn.coilbox",
  "build": {
    "beforeDevCommand": "bun run sidecar:all && bun run heal:perm-cache && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run heal:perm-cache && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Coilbox",
        "width": 1100,
        "height": 720,
        "minWidth": 600,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": [
      "binaries/pr-downloader",
      "binaries/uberstress",
      "binaries/coilbox-unitsync-worker"
    ],
    "resources": ["mapconv"],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist",
      "dmg": {
        "windowSize": { "width": 700, "height": 450 },
        "appPosition": { "x": 200, "y": 195 },
        "applicationFolderPosition": { "x": 500, "y": 195 }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tomjn/coilbox/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1QTYzQUU2OTZBN0QyMTcKUldRWDBxZVc1anFtWlVOM0t2NEFxbXhLMmJaYmtZVm9ZM1V6QVVwaDEwTWJvRWFZdTM4NUZDNlUK"
    }
  }
}
