node_modules
dist
.DS_Store

# Rust / Tauri (workspace target lives at the repo root)
/target
src-tauri/target

# mapconv sidecars are fetched from SpringMapConvNG releases at build time
# (see scripts/fetch-mapconv.sh + .github/workflows/release.yml), not committed.
# Bundled as a Tauri resource folder (binaries + their libs/).
src-tauri/mapconv/

# The unitsync worker is our own workspace crate, built as an externalBin sidecar
# (scripts/build-unitsync-worker.sh locally, release.yml per-platform in CI).
# It's a build artifact, not a committed prebuilt like pr-downloader/uberstress.
src-tauri/binaries/coilbox-unitsync-worker-*
